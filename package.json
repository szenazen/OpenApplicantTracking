{
  "name": "openapplicanttracking",
  "version": "0.1.0",
  "private": true,
  "description": "Open-source, multi-tenant, multi-region Applicant Tracking System.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/szenazen/OpenApplicantTracking.git"
  },
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:e2e": "turbo run test:e2e",
    "db:migrate": "pnpm --filter @oat/api db:migrate",
    "db:seed": "pnpm --filter @oat/api db:seed",
    "dev:account-service": "pnpm --filter @oat/account-service dev",
    "build:account-service": "pnpm --filter @oat/account-service build",
    "compose:gateway": "docker compose -f docker-compose.yml -f docker-compose.microservices.yml up -d --build",
    "dev:web-bff": "pnpm --filter @oat/web-bff dev",
    "dev:pipeline-service": "pnpm --filter @oat/pipeline-service dev",
    "dev:auth-service": "pnpm --filter @oat/auth-service dev",
    "dev:kafka-ping": "pnpm --filter @oat/kafka-ping dev",
    "clean": "turbo run clean && rm -rf node_modules .turbo"
  },
  "devDependencies": {
    "turbo": "^2.1.0",
    "typescript": "^5.5.4",
    "prettier": "^3.3.3"
  }
}
