// =============================================================================
// Regional datasource.
//
// Deployed once per AWS region. Holds the business data that must stay in its
// home region for data-residency compliance:
//   - Account (full record; subset mirrored to global AccountDirectory)
//   - Jobs, Pipelines, Statuses
//   - Candidates (+ skill tags)
//   - Applications (Candidate ↔ Job, with current status in the pipeline)
//   - Files metadata (CVs live in regional object storage)
//   - Regional audit log
//   - Skills read-cache (eventually consistent from global source of truth)
//
// The Prisma client for this schema is instantiated N times (one per region's
// DATABASE_URL) by the RegionRouter. All queries include `accountId` as a
// tenant filter — enforced by guard + middleware.
// =============================================================================

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/regional"
}

datasource db {
  provider = "postgresql"
  url      = env("REGIONAL_DATABASE_URL")
}

// -----------------------------------------------------------------------------
// Accounts (regional copy — full business record)
// -----------------------------------------------------------------------------

model Account {
  id              String   @id                // same id as AccountDirectory in global
  name            String
  slug            String   @unique
  region          String                       // denormalized for convenience
  billingEmail    String?
  settings        Json     @default("{}")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  jobs            Job[]
  pipelines       Pipeline[]
  candidates      Candidate[]
  applications    Application[]
  auditEvents     AuditEvent[]
  files           File[]
  jobNotes        JobNote[]
  jobMembers      JobMember[]
  candidateImports CandidateImport[]
  applicationComments  ApplicationComment[]
  applicationReactions ApplicationReaction[]

  @@map("accounts")
}

// -----------------------------------------------------------------------------
// Pipelines (ordered statuses per-account, optionally per-job)
// -----------------------------------------------------------------------------

model Pipeline {
  id              String   @id @default(cuid())
  accountId       String
  name            String                       // "Default Engineering Pipeline"
  description     String?
  isDefault       Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  account         Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  statuses        PipelineStatus[]
  jobs            Job[]

  @@unique([accountId, name])
  @@index([accountId])
  @@map("pipelines")
}

model PipelineStatus {
  id              String   @id @default(cuid())
  pipelineId      String
  name            String                       // "Applied", "HR Interview", ...
  position        Int                          // order (0-based)
  color           String?                      // hex for UI
  category        StatusCategory @default(IN_PROGRESS)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  pipeline        Pipeline @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  applications    Application[]

  @@unique([pipelineId, name])
  @@unique([pipelineId, position])
  @@index([pipelineId])
  @@map("pipeline_statuses")
}

enum StatusCategory {
  NEW              // e.g. "New candidate", "Applied"
  IN_PROGRESS      // e.g. "Screening", "Interview"
  HIRED            // terminal-success
  DROPPED          // terminal-failure (rejected, withdrew, ghosted)
}

// -----------------------------------------------------------------------------
// Jobs
// -----------------------------------------------------------------------------

model Job {
  id              String   @id @default(cuid())
  accountId       String
  title           String
  description     String?
  department      String?
  location        String?
  employmentType  EmploymentType @default(FULL_TIME)
  status          JobStatus      @default(DRAFT)
  pipelineId      String
  requiredSkillIds String[] @default([])        // referencing Skill.id from global
  openedAt        DateTime?
  closedAt        DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  account         Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  pipeline        Pipeline @relation(fields: [pipelineId], references: [id])
  applications    Application[]
  notes           JobNote[]
  members         JobMember[]

  @@index([accountId, status])
  @@map("jobs")
}

enum EmploymentType {
  FULL_TIME
  PART_TIME
  CONTRACT
  INTERNSHIP
  TEMPORARY
}

enum JobStatus {
  DRAFT
  PUBLISHED
  ON_HOLD
  CLOSED
  ARCHIVED
}

// -----------------------------------------------------------------------------
// Candidates
// -----------------------------------------------------------------------------

model Candidate {
  id              String   @id @default(cuid())
  accountId       String
  firstName       String
  lastName        String
  email           String?
  phone           String?
  headline        String?
  location        String?
  currentCompany  String?
  currentTitle    String?
  yearsExperience Int?
  summary         String?
  source          String?                      // e.g. "manual", "linkedin", "referral"
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  account         Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  applications    Application[]
  files           File[]
  skills          CandidateSkill[]
  imports         CandidateImport[]

  @@unique([accountId, email])
  @@index([accountId])
  @@map("candidates")
}

// Junction table between Candidate and the regional Skill cache — matches the
// CANDIDATE_SKILLS entity in design/ATS-design.drawio.xml. `level` is an
// optional self-assessed 1..5 proficiency score.
model CandidateSkill {
  candidateId String
  skillId     String
  level       Int?                              // 1..5 proficiency (nullable = unscored)
  createdAt   DateTime @default(now())

  candidate   Candidate  @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  skill       SkillCache @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@id([candidateId, skillId])
  @@index([skillId])
  @@map("candidate_skills")
}

// -----------------------------------------------------------------------------
// Applications = Candidate ↔ Job (+ current pipeline status)
// -----------------------------------------------------------------------------

model Application {
  id                 String   @id @default(cuid())
  accountId          String
  candidateId        String
  jobId              String
  currentStatusId    String
  position           Int      @default(0)       // order within status column
  version            Int      @default(0)       // optimistic-concurrency token (see design APPLICATIONS.version)
  appliedAt          DateTime @default(now())
  lastTransitionAt   DateTime @default(now())
  notes              String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  account            Account        @relation(fields: [accountId], references: [id], onDelete: Cascade)
  candidate          Candidate      @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  job                Job            @relation(fields: [jobId], references: [id], onDelete: Cascade)
  currentStatus      PipelineStatus @relation(fields: [currentStatusId], references: [id])
  transitions        ApplicationTransition[]
  comments           ApplicationComment[]
  reactions          ApplicationReaction[]

  @@unique([candidateId, jobId])
  @@index([jobId, currentStatusId, position])
  @@index([accountId])
  @@map("applications")
}

model ApplicationTransition {
  id              String   @id @default(cuid())
  applicationId   String
  fromStatusId    String?
  toStatusId      String
  byUserId        String                        // global user id
  reason          String?
  // Client-supplied retry key. When the same key is retried for the same
  // application the move is a no-op that returns the already-applied state.
  // Matches design APPLICATION_STATUS_HISTORY.idempotency_key.
  idempotencyKey  String?
  createdAt       DateTime @default(now())

  application     Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@unique([applicationId, idempotencyKey])
  @@index([applicationId, createdAt])
  @@map("application_transitions")
}

// -----------------------------------------------------------------------------
// Files (CV, etc.) — metadata only; content lives in regional S3/MinIO.
// -----------------------------------------------------------------------------

model File {
  id              String   @id @default(cuid())
  accountId       String
  candidateId     String?
  kind            FileKind
  filename        String
  mimeType        String
  sizeBytes       Int
  bucket          String
  objectKey       String
  uploadedById    String                       // global user id
  parsedText      String?                      // filled by CV parser worker
  parsedAt        DateTime?
  createdAt       DateTime @default(now())

  account         Account    @relation(fields: [accountId], references: [id], onDelete: Cascade)
  candidate       Candidate? @relation(fields: [candidateId], references: [id], onDelete: SetNull)

  @@index([accountId])
  @@index([candidateId])
  @@map("files")
}

enum FileKind {
  CV
  ATTACHMENT
  AVATAR
}

// -----------------------------------------------------------------------------
// Audit log (regional, partitioned by account)
// -----------------------------------------------------------------------------

model AuditEvent {
  id              String   @id @default(cuid())
  accountId       String
  actorUserId     String?
  action          String                        // e.g. "application.moved", "job.created"
  resource        String                        // e.g. "application:<id>"
  metadata        Json     @default("{}")
  createdAt       DateTime @default(now())

  account         Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId, createdAt])
  @@index([resource])
  @@map("audit_events")
}

// -----------------------------------------------------------------------------
// Job notes (free-form collaboration notes attached to a job opening).
//
// Follows the reliability callouts in design/ATS-design.drawio.xml (Notes):
//   - `idempotencyKey` + unique([jobId, idempotencyKey]) protects against
//     duplicate creates on user retries.
//   - `version` is the optimistic-concurrency token used on update/delete
//     to prevent silent overwrites between collaborators.
// Deletes are soft (`deletedAt`) so the Activities feed can still reference
// authored-then-removed notes.
// -----------------------------------------------------------------------------

model JobNote {
  id              String    @id @default(cuid())
  accountId       String
  jobId           String
  authorUserId    String                           // global user id
  body            String                           // plain text / markdown
  version         Int       @default(0)
  idempotencyKey  String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  account         Account @relation(fields: [accountId], references: [id], onDelete: Cascade)
  job             Job     @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([jobId, idempotencyKey])
  @@index([jobId, createdAt])
  @@index([accountId])
  @@map("job_notes")
}

// -----------------------------------------------------------------------------
// Application-scoped collaboration: comments and reactions on a specific
// candidate's application. These complement the global-per-job Notes with
// lighter-weight, candidate-specific feedback from HR + hiring managers.
//
// Reliability (mirrors JobNote):
//   - `idempotencyKey` + unique([applicationId, idempotencyKey]) protects
//     POSTs against double-submit on retries.
//   - `version` is the optimistic-concurrency token used on update/delete.
// Deletes are soft so the Activities tab can surface an "author removed a
// comment" entry when we build it.
// -----------------------------------------------------------------------------

model ApplicationComment {
  id              String    @id @default(cuid())
  accountId       String
  applicationId   String
  authorUserId    String                           // global user id
  body            String
  version         Int       @default(0)
  idempotencyKey  String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  account         Account     @relation(fields: [accountId], references: [id], onDelete: Cascade)
  application     Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@unique([applicationId, idempotencyKey])
  @@index([applicationId, createdAt])
  @@index([accountId])
  @@map("application_comments")
}

/// One reaction (thumbs-up / thumbs-down / star) per (application, user, kind).
/// Toggling off is a DELETE. Each user can hold each kind independently — it's
/// fine to star AND thumbs-up, but impossible to double-star.
enum ApplicationReactionKind {
  THUMBS_UP
  THUMBS_DOWN
  STAR
}

model ApplicationReaction {
  id              String    @id @default(cuid())
  accountId       String
  applicationId   String
  userId          String                           // global user id
  kind            ApplicationReactionKind
  createdAt       DateTime  @default(now())

  account         Account     @relation(fields: [accountId], references: [id], onDelete: Cascade)
  application     Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@unique([applicationId, userId, kind])
  @@index([applicationId, kind])
  @@index([accountId])
  @@map("application_reactions")
}

// -----------------------------------------------------------------------------
// Job members — job-level collaborators (recruiters, hiring managers, etc.).
//
// Distinct from account-level Memberships in the global DB: a user can be a
// member of the account without being on every job's hiring committee. The
// `role` is a free-form string with a small recommended vocabulary on the
// frontend so we can evolve without a migration.
// -----------------------------------------------------------------------------

enum JobMemberRole {
  OWNER            // accountable for the requisition end-to-end
  RECRUITER
  HIRING_MANAGER
  INTERVIEWER
  OBSERVER
}

model JobMember {
  id              String         @id @default(cuid())
  accountId       String
  jobId           String
  userId          String                              // global user id
  role            JobMemberRole  @default(RECRUITER)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  createdBy       String?                             // global user id who added them

  account         Account @relation(fields: [accountId], references: [id], onDelete: Cascade)
  job             Job     @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([jobId, userId])
  @@index([accountId])
  @@index([jobId])
  @@map("job_members")
}

// -----------------------------------------------------------------------------
// Candidate imports — audit trail for the External Sourcing Service.
//
// Every time a candidate is pulled from an external source (LinkedIn-like
// stub, a pasted URL that gets parsed, a CSV row, etc.) we record the
// attempt here. This gives us:
//   - an audit of "where did this profile come from?" per candidate,
//   - natural idempotency via unique([accountId, source, externalId]) so
//     importing the same profile twice is a no-op,
//   - observability on the sourcing funnel (search -> import -> hired).
// The `rawPayload` keeps the source's original JSON so we can re-parse as
// the parser improves without another round-trip.
// -----------------------------------------------------------------------------

enum CandidateImportStatus {
  PENDING
  COMPLETED
  FAILED
}

model CandidateImport {
  id              String                 @id @default(cuid())
  accountId       String
  candidateId     String?                                  // null until parse succeeds
  source          String                                   // e.g. "linkedin-stub", "paste-url"
  externalId      String                                   // id within the source system
  status          CandidateImportStatus  @default(PENDING)
  error           String?
  rawPayload      Json                   @default("{}")
  createdBy       String                                   // global user id of actor
  jobId           String?                                  // optional — created an application on this job
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt

  account         Account    @relation(fields: [accountId], references: [id], onDelete: Cascade)
  candidate       Candidate? @relation(fields: [candidateId], references: [id], onDelete: SetNull)

  @@unique([accountId, source, externalId])
  @@index([accountId, createdAt])
  @@index([jobId])
  @@map("candidate_imports")
}

// -----------------------------------------------------------------------------
// Regional skill cache (read-only, replicated from global)
// -----------------------------------------------------------------------------

model SkillCache {
  id              String   @id                 // matches global Skill.id
  slug            String   @unique
  name            String
  category        String?
  synonyms        String[] @default([])
  updatedAt       DateTime @default(now())

  candidates      CandidateSkill[]

  @@index([category])
  @@map("skill_cache")
}
