# ============================================================================
# OpenApplicantTracking — environment template
# Copy to `.env` and adjust. Values here work with the bundled docker-compose.
#
# Architecture: primary edge is Web BFF (:3080) + services; apps/api (:3001) is
# backup for unmigrated routes. See docs/deployment-modes.md.
# ============================================================================

NODE_ENV=development
LOG_LEVEL=debug

# ---------- Auth / JWT ----------
JWT_SECRET=change-me-to-a-long-random-string
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
BCRYPT_ROUNDS=10

# ---------- Global control-plane datasource ----------
# Holds users, auth credentials, accounts directory, skills catalog, RBAC.
GLOBAL_DATABASE_URL=postgresql://oat:oat@localhost:5432/oat_global?schema=public

# ---------- Regional datasources (account data residency) ----------
# Region code -> connection string. The API's RegionRouter selects the right
# datasource per request based on the active account's region.
REGION_US_EAST_1_DATABASE_URL=postgresql://oat:oat@localhost:5433/oat_us_east_1?schema=public
REGION_EU_WEST_1_DATABASE_URL=postgresql://oat:oat@localhost:5434/oat_eu_west_1?schema=public
REGION_AP_SOUTHEAST_1_DATABASE_URL=postgresql://oat:oat@localhost:5435/oat_ap_southeast_1?schema=public
REGION_AP_NORTHEAST_1_DATABASE_URL=postgresql://oat:oat@localhost:5436/oat_ap_northeast_1?schema=public
REGION_AP_SOUTHEAST_2_DATABASE_URL=postgresql://oat:oat@localhost:5437/oat_ap_southeast_2?schema=public

# ---------- Redis (sessions, rate limit, socket.io adapter) ----------
REDIS_URL=redis://localhost:6379

# ---------- Kafka / Redpanda (domain events, audit, CV parse jobs) ----------
KAFKA_BROKERS=localhost:19092
KAFKA_CLIENT_ID=oat-api

# ---------- Object storage (MinIO locally, S3 in prod) ----------
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=oat-uploads
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_FORCE_PATH_STYLE=true

# ---------- SMTP (MailHog locally) ----------
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM="OpenATS <no-reply@openapplicanttracking.local>"

# ---------- API / Web ----------
API_PORT=3001
API_URL=http://localhost:3001
WEB_PORT=3002
WEB_URL=http://localhost:3002
# OAT web on 3002; add 3000 if you run another UI against the same API
CORS_ORIGINS=http://localhost:3002,http://localhost:3000
# When using docker compose with the Web BFF (see docker-compose.microservices.yml + services/README),
# set both to the BFF (single entry, aligns with design/ATS-design.drawio.xml):
# API_URL=http://localhost:3080
# In apps/web, point the UI at the BFF: NEXT_PUBLIC_API_URL=http://localhost:3080

# ---------- Account microservice (strangler extract; optional) ----------
# Same JWT_SECRET and GLOBAL_DATABASE_URL as the monolith. Run: pnpm dev:account-service
ACCOUNT_SERVICE_PORT=3010
# Web BFF (compose overlay) — published port for the unified API; BFF routes account slice → account-service
GATEWAY_PORT=3080
# Microservices-mode only (host dev; set in docker-compose.microservices.yml for containers):
# PIPELINE_SLICE_ENABLED=1
# AUTH_SLICE_ENABLED=1
# PIPELINE_SERVICE_URL=http://localhost:3030
# When using Web BFF (docker-compose.microservices.yml) with BFF_PIPELINES_TO_SLICE=1, the BFF
# rewrites /api/pipelines to pipeline-service; you do not need OAT_USE_PIPELINE_SLICE on the monolith.
# Optional: if you call the monolith on :3001 directly, delegate with:
# OAT_USE_PIPELINE_SLICE=true
# PIPELINE_SLICE_BASE_URL=http://127.0.0.1:3030
# AUTH_SERVICE_URL=http://localhost:3020
# KAFKA_PING_URL=http://localhost:3040
# Pipeline slice DB (separate from apps/api regional DBs): only for services/pipeline-service
# PIPELINE_SLICE_DATABASE_URL=postgresql://oat:oat@localhost:5440/oat_pipeline_slice?schema=public

# ---------- Realtime ----------
SOCKETIO_PATH=/realtime
